# Google Gemini Configuration
GOOGLE_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-3.0-flash

# Application State Database (SQLModel/PostgreSQL)
# For local SQLite development: sqlite:///./app_state.db
# For production PostgreSQL: postgresql://user:password@localhost:5432/architect_ai
APP_DATABASE_URL=sqlite:///./app_state.db

# Backend Configuration
PORT=8000
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# Target Database Connection (Default placeholder)
# These will be updated dynamically via the /api/datasources endpoint,
# but can be used for initial setup if needed.
DEFAULT_DB_CONNECTION_URI=postgresql://user:password@localhost:5432/target_db
